{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["bonsai"],
  "title": "Bonsai — Overview",
  "uid": "bonsai-overview",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Answers / min (last 5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(rate(bonsai_answers_total[5m])) * 60" } ]
    },
    {
      "id": 2, "type": "stat", "title": "Refusal rate %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.3 }, { "color": "red", "value": 0.6 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(rate(bonsai_answers_total{refused=\"true\"}[5m])) / clamp_min(sum(rate(bonsai_answers_total[5m])), 1e-9)" } ]
    },
    {
      "id": 3, "type": "stat", "title": "Escalations / min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(rate(bonsai_escalations_total[5m])) * 60" } ]
    },
    {
      "id": 4, "type": "stat", "title": "Rate-limit blocks / min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(rate(bonsai_rate_limit_blocked_total[5m])) * 60" } ]
    },
    {
      "id": 5, "type": "timeseries", "title": "HTTP requests / s by status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [ { "refId": "A", "legendFormat": "{{status_code}}", "expr": "sum by (status_code) (rate(bonsai_http_request_duration_seconds_count[5m]))" } ]
    },
    {
      "id": 6, "type": "timeseries", "title": "HTTP errors (5xx) / s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 20 }, "color": { "mode": "fixed", "fixedColor": "red" } } },
      "targets": [ { "refId": "A", "legendFormat": "5xx", "expr": "sum(rate(bonsai_http_request_duration_seconds_count{status_code=~\"5..\"}[5m]))" } ]
    },
    {
      "id": 7, "type": "timeseries", "title": "HTTP latency (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "legendFormat": "p50", "expr": "histogram_quantile(0.50, sum by (le) (rate(bonsai_http_request_duration_seconds_bucket[5m])))" },
        { "refId": "B", "legendFormat": "p95", "expr": "histogram_quantile(0.95, sum by (le) (rate(bonsai_http_request_duration_seconds_bucket[5m])))" },
        { "refId": "C", "legendFormat": "p99", "expr": "histogram_quantile(0.99, sum by (le) (rate(bonsai_http_request_duration_seconds_bucket[5m])))" }
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Ingestion outcomes / s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "targets": [ { "refId": "A", "legendFormat": "{{status}}", "expr": "sum by (status) (rate(bonsai_ingestion_total[5m]))" } ]
    },
    {
      "id": 9, "type": "timeseries", "title": "LLM & embedding calls / s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "targets": [
        { "refId": "A", "legendFormat": "llm {{provider}}", "expr": "sum by (provider) (rate(bonsai_llm_calls_total[5m]))" },
        { "refId": "B", "legendFormat": "embed {{provider}}", "expr": "sum by (provider) (rate(bonsai_embedding_calls_total[5m]))" }
      ]
    },
    {
      "id": 10, "type": "timeseries", "title": "Process memory (RSS) & event-loop lag",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [ { "matcher": { "id": "byName", "options": "event-loop lag (s)" }, "properties": [ { "id": "unit", "value": "s" } ] } ] },
      "targets": [
        { "refId": "A", "legendFormat": "RSS", "expr": "process_resident_memory_bytes" },
        { "refId": "B", "legendFormat": "event-loop lag (s)", "expr": "nodejs_eventloop_lag_seconds" }
      ]
    }
  ]
}
