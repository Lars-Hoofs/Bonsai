# --- Core ---
DATABASE_URL=postgres://bonsai:bonsai_dev@localhost:5432/bonsai
PORT=3000
NODE_ENV=development

# --- Auth (managed EU OIDC provider) ---
OIDC_ISSUER=https://your-idp.example.eu
OIDC_AUDIENCE=bonsai-api
OIDC_JWKS_URL=https://your-idp.example.eu/oauth/v2/keys

# --- Embeddings (external API; everything else self-hosted on the VPS) ---
# Leave unset in dev/test to use the deterministic in-process fake provider.
EMBEDDING_API_URL=https://your-embeddings.example.eu/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=your-embedding-model
# MUST match the pgvector column dimension (default 1024). Changing this later
# requires a migration + re-embed.
EMBEDDING_DIM=1024

# --- Answer LLM (external API, lightweight/"mini/flash/haiku"-class) ---
# Leave unset in dev/test to use the deterministic in-process fake provider.
LLM_API_URL=https://your-llm.example.eu/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=your-small-model

# --- Limits ---
RATE_LIMIT_PER_MINUTE=120
