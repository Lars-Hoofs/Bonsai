# --- Core ---
# Host port 5439 matches docker-compose.yml (avoids the common 5432 conflict).
DATABASE_URL=postgres://bonsai:bonsai_dev@localhost:5439/bonsai
PORT=3000
NODE_ENV=development

# --- Auth (managed EU OIDC provider) ---
# The verifier requires email_verified=true and pins RS256.
OIDC_ISSUER=https://your-idp.example.eu
OIDC_AUDIENCE=bonsai-api
OIDC_JWKS_URL=https://your-idp.example.eu/oauth/v2/keys

# --- Embeddings (external API; everything else self-hosted on the VPS) ---
# Leave unset in dev/test to use the deterministic in-process fake provider.
EMBEDDING_API_URL=https://your-embeddings.example.eu/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=your-embedding-model
# MUST match the pgvector column dimension (default 1024). Changing it later
# requires a migration + re-embed.
EMBEDDING_DIM=1024

# --- Answer LLM (external API, lightweight "mini/flash/haiku"-class) ---
LLM_API_URL=https://your-llm.example.eu/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=your-small-model
# Second-pass groundedness self-check (extra small LLM call). true|false.
SELF_CHECK_ENABLED=true

# --- Reranker (optional external API; falls back to a lexical fake) ---
RERANK_API_URL=
RERANK_API_KEY=
RERANK_MODEL=

# --- Redis (scheduled website re-crawl; unset disables it) ---
REDIS_URL=redis://localhost:6379
RECRAWL_INTERVAL_MS=86400000

# --- Object storage (MinIO / S3-compatible; unset keeps only extracted text) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=bonsai-uploads

# --- Limits ---
RATE_LIMIT_PER_MINUTE=120
# Per-endpoint public rate limits (operator-tunable without a redeploy).
WIDGET_CONFIG_RATE_PER_MIN=60
CONVERSATION_START_RATE_PER_MIN=20

# --- Billing ---
# OFF for now: every tenant runs as if on a paid plan (usage is metered but the
# quota is never enforced). Flip to true once a payment provider is wired.
BILLING_ENABLED=false

# --- Mail (self-hosted SMTP; free, no paid email service) ---
# Used for team invitation emails (and later features). Unset SMTP_HOST means
# mail sending is a no-op (logged at debug only) — safe default for dev/test.
# Fill these in with your own SMTP relay/mailbox credentials for real sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# 'true' for implicit TLS (e.g. port 465); 'false' (default) for STARTTLS (587).
SMTP_SECURE=false

# --- OCR (self-hosted Tesseract via tesseract.js; free, no paid service) ---
# Fallback text extraction for scanned PDFs/images (little/no extractable
# text from normal parsing). In-process WASM OCR — no Docker sidecar needed.
OCR_ENABLED=true
# '+'-joined Tesseract language codes; nld=Dutch, eng=English.
OCR_LANGUAGES=nld+eng
# Cap on PDF pages OCR'd per upload (PDF rasterization is a follow-up; image
# uploads are fully supported today).
OCR_MAX_PAGES=20

# --- Monitoring (self-hosted Prometheus + Grafana; free, no paid service) ---
# Gates GET /metrics. Set the SAME value in monitoring/prometheus/prometheus.yml
# (credentials:). In production, /metrics is hard-disabled when this is unset.
METRICS_TOKEN=change-me-to-a-long-random-string
# Grafana admin password (UI at http://<host>:3001, user: admin).
GRAFANA_ADMIN_PASSWORD=change-me

# --- Plan/tier limits (self-managed; no billing provider required) ---
# Optional JSON object mapping a tenant's `plan` column value to its limits,
# e.g. '{"starter":{"maxProjects":2,"maxSourcesPerProject":20,"maxMembers":10}}'.
# Any plan omitted here (or when this is unset entirely) falls back to the
# built-in defaults in src/config/config.ts. A field set to `null` (or the
# built-in 'enterprise' plan) means "no limit" for that dimension.
PLAN_LIMITS_JSON=
